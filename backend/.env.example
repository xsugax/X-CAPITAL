# ─── Server ──────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000

# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://xcapital:xcapital_secret@localhost:5432/xcapital_db"

# ─── Auth ────────────────────────────────────────────────────────────────────
JWT_SECRET=replace_with_a_very_long_random_secret_minimum_64_chars
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ─── Frontend ────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Alpaca Brokerage (https://alpaca.markets) ───────────────────────────────
ALPACA_API_KEY=your_alpaca_api_key
ALPACA_SECRET_KEY=your_alpaca_secret_key
ALPACA_BASE_URL=https://paper-api.alpaca.markets
ALPACA_DATA_URL=https://data.alpaca.markets

# ─── DriveWealth (https://drivewealth.com) ───────────────────────────────────
DRIVEWEALTH_API_KEY=your_drivewealth_api_key
DRIVEWEALTH_BASE_URL=https://api.drivewealth.io/latest

# ─── Blockchain / Ethereum ───────────────────────────────────────────────────
ETHEREUM_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/your_alchemy_key
TREASURY_WALLET_ADDRESS=0x0000000000000000000000000000000000000000
TREASURY_PRIVATE_KEY=your_treasury_private_key_keep_secure
XCAPITAL_TOKEN_ADDRESS=0x0000000000000000000000000000000000000000

# ─── AI Oracle Service ────────────────────────────────────────────────────────
AI_ORACLE_URL=http://localhost:8000

# ─── KYC — Stripe Identity / Persona ─────────────────────────────────────────
KYC_PROVIDER=persona
PERSONA_API_KEY=your_persona_api_key
PERSONA_TEMPLATE_ID=your_persona_template_id

# ─── Payments — Stripe ───────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret

# ─── Secondary Market Partners ───────────────────────────────────────────────
FORGE_API_KEY=your_forge_global_api_key
EQUITYZEN_API_KEY=your_equityzen_api_key

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
